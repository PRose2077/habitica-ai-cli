# Habitica-Forge 配置文件示例
# 请复制此文件为 .env 并填写您的凭证

# ============================================
# Habitica 认证（必填）
# ============================================
# 在 https://habitica.com/user/settings/api 获取
HABITICA_USER_ID=your-uuid-here
HABITICA_API_TOKEN=your-api-token-here

# ============================================
# LLM 引擎认证（必填）
# ============================================
# 支持 OpenAI 兼容的 API
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ============================================
# 称号掉落权重与算法（可选）
# ============================================
# TODO 任务权重系数
WEIGHT_TODO=1.0
# DAILY 任务权重系数
WEIGHT_DAILY=0.3
# 连击加成系数
DAILY_STREAK_BONUS=0.05
# 触发称号掉落的阈值
TITLE_THRESHOLD=8.5

# ============================================
# 系统行为（可选）
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=WARNING
# 腐烂扫描间隔（小时）
SCAN_INTERVAL_HOURS=12
# 游戏化风格（Cyberpunk, Wuxia, Fantasy...）
FORGE_STYLE=Cyberpunk